# ===== OpenAI / OpenAI互換API の設定 =====
# 公式OpenAIなら base_url は https://api.openai.com/v1。
# /v1 以外のパスのOpenAI互換エンドポイントを使う場合は、そのパスまでを指定する
# （OpenAI SDK が末尾に /chat/completions を自動付与するため、/chat/completions は付けない）。
OPENAI_BASE_URL=https://api.openai.com/v1

# 認証: ヘッダー Authorization: Bearer <API_KEY>（SDKが api_key から自動付与）
OPENAI_API_KEY=<API_KEY>

# モデル名: gpt-4o-mini または gpt-4o（tool calling 対応）
OPENAI_MODEL=gpt-4o-mini

# 生成パラメータ（任意）。SQL生成の安定のため temperature は 0 推奨。
# OPENAI_TEMPERATURE=0
# OPENAI_TOP_P=0.95
# OPENAI_MAX_TOKENS=1500

# ===== データの場所（任意。未設定なら ./data 配下を使用） =====
# 共有フォルダ: 15分毎に更新されるCSVが置かれる場所
# SHARED_FOLDER=//server/share/equipment_status
# 自前のSQLite DB
# DB_PATH=./data/factory.db

# ===== CSVヘッダ名のマッピング（任意） =====
# 本番CSVのヘッダ名が既定(更新日時/建屋/装置ID/チャンバーID/ステータス や英語内部名)と
# 異なる場合の対応表。値は内部列名 updated_at/building/equipment_id/chamber_id/status のいずれか。
#   方法1: csv_mapping.json を置く（csv_mapping.example.json をコピーして編集）
#   方法2: 下記にインラインJSONを設定（ファイルより優先）
# CSV_HEADER_MAP_JSON={"装置番号":"equipment_id","更新時刻":"updated_at"}
# CSV_HEADER_MAP_FILE=./csv_mapping.json
